{
  "name": "world-cup-app",
  "version": "1.0.0",
  "description": "Spicy Thai World Cup Registration App",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "build": "npm install && cd frontend && npm install && npm run build",
    "start:backend": "node server/index.js",
    "start:frontend": "cd frontend && npm run dev -- --host",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "4.19.2",
    "mongoose": "^8.4.1",
    "concurrently": "^8.2.2"
  }
}
